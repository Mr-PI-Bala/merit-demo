# merit-demo — copy to .env.local (never commit .env.local)
# Consumer Supabase project: run sql/001_merit_demo.sql then sql/002_ama_daily_activity.sql
# meritsubs tables: use the hosted MERIT provider for usage, entitlement, and checkout authority

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

MERIT_CONSUMER_ID=merit-demo

# hosted meritsubs / usage relay
MERITSUBS_MOUNT_PREFIX=/api/meritsubs
MERITSUBS_PUBLIC_BASE_URL=https://YOUR_DEPLOY.vercel.app/api/meritsubs
MERITSUBS_PROVIDER_BASE_URL=https://meritstore.vercel.app/api/meritsubs
MERITSTORE_BASE_URL=https://meritstore.vercel.app
MERIT_DEFAULT_PROMOCODE=MERITAGENT
MERIT_INTRO_CREDIT_USD=25
MERITSUBS_JWT_SECRET=generate-32-plus-bytes
MERITSUBS_API_KEY=generate-shared-secret
MERITSUBS_ADMIN_KEY=generate-ops-key

# MeritAdminGate (production: bcrypt hash from vault merit.ps1 admin operator-gate hash)
OPERATOR_GATE_HASH_SLOT_1=
